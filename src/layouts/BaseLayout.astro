---
import "@/styles/global.css";
import { getAdminSession } from "@/lib/auth";
import { getDb } from "@/lib/db";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Lug to Lug Finder",
  description = "Search watch lug-to-lug, case, thickness, lug width, and wrist-fit guidance."
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://lugtolug.example").toString();
const adminSession = await getAdminSession(getDb(Astro.locals), Astro.request);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 48 48" focusable="false">
              <path d="M18 18 13 6M30 18l5-12" />
              <path d="M16 18h16M16 30h16" />
              <circle cx="24" cy="24" r="10" />
              <path d="M24 10V5M24 38v5M10 24H5M38 24h5" />
              <circle class="brand-mark-dot" cx="24" cy="24" r="2.1" />
            </svg>
          </span>
          <span class="brand-copy">
            <span>Lug to Lug Finder</span>
            <small>Horological database & fit analyzer</small>
          </span>
        </a>
        <nav class="nav" aria-label="Main navigation">
          <a href="/watches">Watches</a>
          <a href="/submit">Submit data</a>
          <a href="/" data-saved-count>Saved (0)</a>
          <a href={adminSession ? "/admin/submissions" : "/admin/login"}>
            {adminSession ? "Admin" : "Admin login"}
          </a>
        </nav>
      </header>
      <main class="main">
        <slot />
      </main>
      <footer class="footer">
        Watch fit guidance is approximate. Case shape, end links, strap stiffness, and personal preference can change real-world wear.
      </footer>
    </div>
    <script is:inline>
      (() => {
        const key = "lugtolug.saved.v1";
        const target = document.querySelector("[data-saved-count]");
        const readCount = () => {
          try {
            const value = localStorage.getItem(key);
            const parsed = value ? JSON.parse(value) : [];
            return Array.isArray(parsed) ? parsed.length : 0;
          } catch {
            return 0;
          }
        };
        const render = () => {
          if (target) target.textContent = `Saved (${readCount()})`;
        };
        window.addEventListener("storage", render);
        window.addEventListener("lugtolug:saved-change", render);
        render();
      })();
    </script>
  </body>
</html>
