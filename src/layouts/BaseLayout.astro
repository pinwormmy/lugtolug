---
import "@/styles/global.css";
import { getAdminSession } from "@/lib/auth";
import { getDb } from "@/lib/db";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Lug to Lug Finder",
  description = "Search watch lug-to-lug, case, thickness, lug width, and wrist-fit guidance."
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://lugtolug.example").toString();
const adminSession = await getAdminSession(getDb(Astro.locals), Astro.request);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 48 48" focusable="false">
              <path class="brand-mark-ear" d="M17.5 20C14.6 14.2 14.1 8.7 17.2 5.7C20.4 9.2 22.1 14.4 22 20" />
              <path class="brand-mark-ear" d="M26 20C25.9 14.4 27.6 9.2 30.8 5.7C33.9 8.7 33.4 14.2 30.5 20" />
              <circle class="brand-mark-case" cx="24" cy="29" r="10.6" />
              <path class="brand-mark-hand" d="M24 29V23.5M24 29l4.4 2.3" />
            </svg>
          </span>
          <span class="brand-copy">
            <span>Lug to Lug Finder</span>
            <small>Horological database & fit analyzer</small>
          </span>
        </a>
        <nav class="nav" aria-label="Main navigation">
          <a href="/watches">Watches</a>
          <a href="/submit">Submit data</a>
          <a href={adminSession ? "/admin/submissions" : "/admin/login"}>
            {adminSession ? "Admin" : "Admin login"}
          </a>
        </nav>
      </header>
      <main class="main">
        <slot />
      </main>
      <footer class="footer">
        Watch fit guidance is approximate. Case shape, end links, strap stiffness, and personal preference can change real-world wear.
      </footer>
    </div>
  </body>
</html>
