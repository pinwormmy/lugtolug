---
import type { WatchWithSources } from "@/types";
import { formatMm, getWatchHref, WATCH_METRICS } from "@/lib/watch";

interface Props {
  watch: WatchWithSources;
}

const { watch } = Astro.props;
const href = getWatchHref(watch);
const watchName = [watch.brand, watch.model].filter(Boolean).join(" ");
---

<a class="watch-row" href={href}>
  <div class="watch-name">
    <strong>{watchName}</strong>
    <span>{watch.reference || "Reference not provided"}</span>
  </div>
  {WATCH_METRICS.map((metric) => (
    <div class="metric">
      <span>{metric.rowLabel}</span>
      <strong>{formatMm(watch[metric.key])}</strong>
    </div>
  ))}
</a>
