---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubmissionForm from "@/components/SubmissionForm";
---

<BaseLayout title="Submit watch data | Lug to Lug Finder" description="Privately submit watch data for operator review.">
  <section class="section" style="margin-top: 0;">
    <h1 class="page-title">Submit watch data</h1>
    <p class="lede">
      Send watch details and a source URL. Your private comment and email are visible only to the operator.
    </p>
  </section>
  <section class="section">
    <SubmissionForm client:load />
  </section>
</BaseLayout>
