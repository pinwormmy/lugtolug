---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WatchesListSearch from "@/components/WatchesListSearch";
import { readSearchState } from "@/lib/searchState";

const initialSearchState = readSearchState(Astro.url.searchParams);
---

<BaseLayout title="Watch database | Lug to Lug Finder" description="Browse approved watch records by brand, model, and reference number.">
  <WatchesListSearch client:load initialQuery={initialSearchState.query} />
</BaseLayout>
