---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WatchesListSearch from "@/components/WatchesListSearch";
import { getDb, listWatches } from "@/lib/db";
import { groupWatchesForDisplay } from "@/lib/watchGroups";

const watches = groupWatchesForDisplay(await listWatches(getDb(Astro.locals)));
---

<BaseLayout title="Watch database | Lug to Lug Finder" description="Browse approved watch records by brand, model, and reference number.">
  <WatchesListSearch client:load watches={watches} />
</BaseLayout>
