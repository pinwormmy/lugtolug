---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CorrectionReportForm from "@/components/CorrectionReportForm";
import FitCalculator from "@/components/FitCalculator";
import { getAdminSession } from "@/lib/auth";
import { getManagePublishedWatchHref } from "@/lib/adminRoutes";
import { getDb, getWatchBySlugs } from "@/lib/db";
import { mmToInches } from "@/lib/fit";
import { formatMm, getWatchDisplayModel, getWatchDisplayName, isHttpUrl, WATCH_METRICS } from "@/lib/watch";

const { brand, model, reference } = Astro.params;
const db = getDb(Astro.locals);
const watch = await getWatchBySlugs(db, brand!, model!, reference!);

if (!watch) {
  return Astro.redirect("/watches", 302);
}

const adminSession = await getAdminSession(db, Astro.request);
const manageHref = getManagePublishedWatchHref(watch);
const watchModel = getWatchDisplayModel(watch);
const watchName = getWatchDisplayName(watch);
const referenceLabel = watch.reference || "Reference not provided";
const variantLabel = watch.variant ? `${referenceLabel} · ${watch.variant}` : referenceLabel;
const formatInches = (value: number | null | undefined) => value == null ? "Not provided" : `${mmToInches(value).toFixed(2)} in`;
const title = `${watchName} | Lug to Lug Finder`;
const description = `${watchName}: ${formatMm(watch.lugToLugMm)} lug-to-lug, ${formatMm(watch.caseMm)} case, ${formatMm(watch.thicknessMm)} thickness, ${formatMm(watch.lugWidthMm)} lug width.`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: watchName,
  ...(watch.brand ? { brand: { "@type": "Brand", name: watch.brand } } : {}),
  ...(watch.reference ? { model: watch.reference } : {}),
  additionalProperty: [
    ...WATCH_METRICS.map((metric) => ({
      "@type": "PropertyValue",
      name: metric.detailLabel,
      value: formatMm(watch[metric.key])
    }))
  ]
};
---

<BaseLayout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <section class="section detail-record" style="margin-top: 0;">
    <div>
      {watch.brand && <p class="eyebrow"><a href={`/brands/${watch.brandSlug}`}>{watch.brand}</a></p>}
      <h1 class="page-title">{watchModel}</h1>
      <p class="lede">{variantLabel}</p>
    </div>
  </section>

  <section class="section spec-grid">
    {WATCH_METRICS.map((metric) => (
      <div class="spec-card">
        <span>{metric.detailLabel}</span>
        <strong>{formatMm(watch[metric.key])}</strong>
        <span>{formatInches(watch[metric.key])}</span>
      </div>
    ))}
  </section>

  <section class="section grid-2">
    <FitCalculator client:load lugToLugMm={watch.lugToLugMm} />
    <div class="panel" id="sources">
      <h2>Sources</h2>
      <ul>
        {watch.sources.map((source) => (
          <li>
            {isHttpUrl(source.sourceUrl) ? (
              <a href={source.sourceUrl} rel="nofollow noreferrer" target="_blank">{source.sourceUrl}</a>
            ) : source.sourceUrl}
            {source.note && <p class="small">{source.note}</p>}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section" id="notes">
    <CorrectionReportForm client:load watch={watch} />
  </section>

  {adminSession && (
    <section class="section" style="padding-top: 0;">
      <p style="margin: 0;">
        <a class="button secondary" href={manageHref}>Manage published data</a>
      </p>
    </section>
  )}
</BaseLayout>
