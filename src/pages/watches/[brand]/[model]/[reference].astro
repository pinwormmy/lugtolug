---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CorrectionReportForm from "@/components/CorrectionReportForm";
import { getAdminSession } from "@/lib/auth";
import { getDb, getWatchBySlugs } from "@/lib/db";
import { formatMm, isHttpUrl, WATCH_METRICS } from "@/lib/watch";

const { brand, model, reference } = Astro.params;
const db = getDb(Astro.locals);
const watch = await getWatchBySlugs(db, brand!, model!, reference!);

if (!watch) {
  return Astro.redirect("/watches", 302);
}

const adminSession = await getAdminSession(db, Astro.request);
const manageHref = `/admin/watches/${watch.id}`;
const watchName = [watch.brand, watch.model].filter(Boolean).join(" ");
const referenceLabel = watch.reference || "Reference not provided";
const title = `${watchName} | Lug to Lug Finder`;
const description = `${watchName}: published measurements, sources, and notes.`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: watchName,
  ...(watch.brand ? { brand: { "@type": "Brand", name: watch.brand } } : {}),
  ...(watch.reference ? { model: watch.reference } : {}),
  additionalProperty: [
    ...WATCH_METRICS.map((metric) => ({
      "@type": "PropertyValue",
      name: metric.detailLabel,
      value: formatMm(watch[metric.key])
    }))
  ]
};
---

<BaseLayout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <section class="section detail-record" style="margin-top: 0;">
    <div>
      {watch.brand && <p class="eyebrow"><a href={`/brands/${watch.brandSlug}`}>{watch.brand}</a></p>}
      <h1 class="page-title">{watch.model}</h1>
      <p class="lede">{referenceLabel}</p>
    </div>
    {adminSession && (
      <p style="margin-top: 18px;">
        <a class="button secondary" href={manageHref}>Manage published data</a>
      </p>
    )}
  </section>

  <section class="section spec-grid">
    {WATCH_METRICS.map((metric) => (
      <div class="spec-card">
        <span>{metric.detailLabel}</span>
        <strong>{formatMm(watch[metric.key])}</strong>
      </div>
    ))}
  </section>

  <section class="section grid-2">
    <div class="panel" id="sources">
      <h2>Sources</h2>
      <p class="small">Confidence: {watch.confidence}</p>
      <ul>
        {watch.sources.map((source) => (
          <li>
            {isHttpUrl(source.sourceUrl) ? (
              <a href={source.sourceUrl} rel="nofollow noreferrer" target="_blank">{source.sourceUrl}</a>
            ) : source.sourceUrl}
            {source.note && <p class="small">{source.note}</p>}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section" id="notes">
    <CorrectionReportForm client:load watch={watch} />
  </section>
</BaseLayout>
