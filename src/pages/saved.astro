---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SavedWatchesApp from "@/components/SavedWatchesApp";
import { getDb, listWatches } from "@/lib/db";

const db = getDb(Astro.locals);
const watches = await listWatches(db);
---

<BaseLayout title="Saved watches | Lug to Lug Finder" description="View watches saved in this browser.">
  <SavedWatchesApp client:load watches={watches} />
</BaseLayout>
