---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WatchRow from "@/components/WatchRow.astro";
import { getDb, listBrandWatches } from "@/lib/db";
import { groupWatchesForDisplay } from "@/lib/watchGroups";
import { resolveOrigin } from "@/lib/seo";

const brandSlug = Astro.params.brand!;
const watches = groupWatchesForDisplay(await listBrandWatches(getDb(Astro.locals), brandSlug));

if (watches.length === 0) {
  return Astro.rewrite("/404");
}

const brandName = watches[0]?.brand ?? brandSlug;
const description = `${brandName} lug-to-lug, case diameter, thickness, and lug width measurements for ${watches.length} watch record${watches.length === 1 ? "" : "s"}.`;
const canonicalUrl = new URL(Astro.url.pathname, resolveOrigin(Astro.site)).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${brandName} watch records`,
  description,
  url: canonicalUrl,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: watches.length
  }
};
---

<BaseLayout title={`${brandName} watch records | Lug to Lug Finder`} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <section class="section" style="margin-top: 0;">
    <h1 class="page-title">{brandName}</h1>
    <p class="lede">Approved records for {brandName} watches.</p>
    <div class="watch-list" style="margin-top: 26px;">
      {watches.map((watch) => <WatchRow watch={watch} />)}
    </div>
  </section>
</BaseLayout>
