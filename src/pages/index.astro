---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SearchApp from "@/components/SearchApp";
import WatchRow from "@/components/WatchRow.astro";
import { getDb, listRecentWatches } from "@/lib/db";
import { readSearchState } from "@/lib/searchState";

const showRecentWatches = false;
const recentWatches = showRecentWatches ? await listRecentWatches(getDb(Astro.locals), 5) : [];
const initialSearchState = readSearchState(Astro.url.searchParams);
---

<BaseLayout title="Lug to Lug Finder | Watch database" description="Search watch records by brand, model, and reference.">
  <section class="home-workbench">
    <SearchApp
      client:load
      initialDimensionFilters={initialSearchState.dimensionFilters}
      initialQuery={initialSearchState.query}
      initialSort={initialSearchState.sort}
    />
  </section>

  {
    showRecentWatches && (
      <section class="section" data-recent-watches>
        <h2>Recently approved watches</h2>
        <div class="watch-list">
          {recentWatches.map((watch) => <WatchRow watch={watch} />)}
        </div>
      </section>
    )
  }
</BaseLayout>
