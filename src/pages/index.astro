---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SearchApp from "@/components/SearchApp";
import WatchRow from "@/components/WatchRow.astro";
import { getDb, listWatches } from "@/lib/db";

const watches = await listWatches(getDb(Astro.locals));
const featured = watches.slice(0, 4);
---

<BaseLayout title="Lug to Lug Finder | Watch fit dimensions" description="Search watch lug-to-lug, case diameter, thickness, lug width, and wrist fit guidance.">
  <section class="hero">
    <div>
      <h1>Find the watch size that actually wears right.</h1>
      <p>
        Search by brand, model, or reference number to compare lug-to-lug, case diameter, thickness, lug width, and wrist-fit guidance.
      </p>
    </div>
    <SearchApp client:load watches={watches} />
  </section>

  <section class="section">
    <h2>Recently added watches</h2>
    <div class="watch-list">
      {featured.map((watch) => <WatchRow watch={watch} />)}
    </div>
  </section>
</BaseLayout>
