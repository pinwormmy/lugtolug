---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdminWatchForm from "@/components/AdminWatchForm.astro";
import { getAdminSession } from "@/lib/auth";
import { getDb, getSubmission } from "@/lib/db";

const db = getDb(Astro.locals);
const session = await getAdminSession(db, Astro.request);
if (!session) {
  return Astro.redirect("/admin/login", 302);
}

const submission = await getSubmission(db, Number(Astro.params.id));
if (!submission) {
  return Astro.redirect("/admin/submissions", 302);
}
const payload = submission.payload;
const isPending = submission.status === "pending";
const isApproved = submission.status === "approved";
const isCorrection = payload.submissionType === "correction";
const updated = Astro.url.searchParams.get("updated") === "1";
const validationError = Astro.url.searchParams.get("error") === "validation";
---

<BaseLayout title="Review submission | Lug to Lug Finder" description="Review one private watch submission." noindex>
  <section class="section" style="margin-top: 0;">
    <h1 class="page-title" style="font-size: clamp(2.4rem, 6vw, 4rem);">Review submission</h1>
    <p class="lede">{[payload.brand, payload.model].filter(Boolean).join(" ")} · {payload.reference || "No reference"} · {isCorrection ? "Correction report" : "New watch"} · {submission.status}</p>
    {(updated || validationError) && (
      <p class={validationError ? "error" : "notice"} style="margin-top: 18px;">
        {updated && "Published submission updated."}
        {validationError && "Check the submitted fields and try again."}
      </p>
    )}
    {!isPending && (
      <p class="notice" style="margin-top: 18px;">
        This submission was already {submission.status}
        {submission.reviewedAt ? ` on ${new Date(submission.reviewedAt).toLocaleString("en-US")}` : ""}.
      </p>
    )}
  </section>

  <section class="section grid-2">
    {(isPending || isApproved) ? (
      <AdminWatchForm
        action={isPending ? `/api/admin/submissions/${submission.id}/approve` : `/api/admin/submissions/${submission.id}/update`}
        csrfToken={session.csrfToken}
        payload={payload}
        submitLabel={isPending ? "Approve and publish" : "Save published changes"}
        hiddenFields={{
          submissionType: payload.submissionType ?? "new-watch",
          reportedWatchId: payload.reportedWatchId,
          reportedWatchPath: payload.reportedWatchPath
        }}
        includeReviewerNote
        reviewerNote={isApproved ? submission.reviewerNote : ""}
      />
    ) : (
      <div class="panel">
        <h2>Reviewed result</h2>
        <p><strong>Status:</strong> {submission.status}</p>
        <p><strong>Reviewer note:</strong> {submission.reviewerNote || "No reviewer note."}</p>
      </div>
    )}

    <div class="panel">
      <h2>Private contributor details</h2>
      {isCorrection && (
        <p><strong>Reported page:</strong> {payload.reportedWatchPath ? <a href={payload.reportedWatchPath}>{payload.reportedWatchPath}</a> : "Not provided"}</p>
      )}
      <p><strong>Email:</strong> {payload.contactEmail || "Not provided"}</p>
      <p><strong>Private comment:</strong></p>
      <p>{payload.privateComment || "No private comment."}</p>
      {isPending && (
        <form action={`/api/admin/submissions/${submission.id}/reject`} method="post">
          <input type="hidden" name="csrfToken" value={session.csrfToken} />
          <label for="rejectNote">Rejection note</label>
          <textarea class="textarea" id="rejectNote" name="reviewerNote"></textarea>
          <button class="button danger" type="submit" style="margin-top: 12px;">Reject</button>
        </form>
      )}
      {isApproved && (
        <form action={`/api/admin/submissions/${submission.id}/unapprove`} method="post">
          <input type="hidden" name="csrfToken" value={session.csrfToken} />
          <label for="unapproveNote">Return to pending note</label>
          <textarea class="textarea" id="unapproveNote" name="reviewerNote">{submission.reviewerNote ?? ""}</textarea>
          <button class="button danger" type="submit" style="margin-top: 12px;">Return to pending</button>
        </form>
      )}
    </div>
  </section>
</BaseLayout>
