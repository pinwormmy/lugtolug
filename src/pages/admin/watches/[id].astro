---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdminWatchForm from "@/components/AdminWatchForm.astro";
import { getAdminSession } from "@/lib/auth";
import { getDb, getWatchById } from "@/lib/db";
import { isHttpUrl } from "@/lib/watch";
import type { SubmissionPayload } from "@/types";

const db = getDb(Astro.locals);
const session = await getAdminSession(db, Astro.request);
if (!session) {
  return Astro.redirect("/admin/login", 302);
}

const id = Number(Astro.params.id);
const watch = Number.isSafeInteger(id) ? await getWatchById(db, id) : null;
if (!watch) {
  return Astro.redirect("/watches", 302);
}

const sourceUrl = watch.sources[0]?.sourceUrl ?? "";
const payload = {
  brand: watch.brand,
  model: watch.model,
  reference: watch.reference,
  lugToLugMm: watch.lugToLugMm,
  caseMm: watch.caseMm,
  thicknessMm: watch.thicknessMm,
  lugWidthMm: watch.lugWidthMm,
  sourceUrl
} satisfies SubmissionPayload;
const updated = Astro.url.searchParams.get("updated") === "1";
const pending = Astro.url.searchParams.get("pending") === "1";
const validationError = Astro.url.searchParams.get("error") === "validation";
---

<BaseLayout title="Manage watch | Lug to Lug Finder" description="Edit a published watch record.">
  <section class="section" style="margin-top: 0;">
    {watch.status === "approved" && (
      <p class="small"><a href={`/watches/${watch.brandSlug}/${watch.modelSlug}/${watch.referenceSlug}`}>View public page</a></p>
    )}
    <h1 class="page-title" style="font-size: clamp(2.4rem, 6vw, 4rem);">Manage watch</h1>
    <p class="lede">{[watch.brand, watch.model].filter(Boolean).join(" ")} · {watch.reference || "No reference"} · {watch.status}</p>
    {(updated || pending || validationError) && (
      <p class={validationError ? "error" : "notice"} style="margin-top: 18px;">
        {updated && "Watch record updated."}
        {pending && "Watch record returned to pending."}
        {validationError && "Check the submitted fields and try again."}
      </p>
    )}
  </section>

  <section class="section grid-2">
    <AdminWatchForm
      action={`/api/admin/watches/${watch.id}/update`}
      csrfToken={session.csrfToken}
      payload={payload}
      submitLabel="Save watch changes"
    />

    <div class="panel">
      <h2>Publishing</h2>
      <p><strong>Status:</strong> {watch.status}</p>
      <p class="small">Use the button below to move this record back to pending without changing the edit form.</p>
      <form action={`/api/admin/watches/${watch.id}/unpublish`} method="post">
        <input type="hidden" name="csrfToken" value={session.csrfToken} />
        <button class="button danger" type="submit" style="margin-top: 12px;">Mark as pending</button>
      </form>

      <h2 style="margin-top: 24px;">Sources</h2>
      <ul>
        {watch.sources.map((source) => (
          <li>
            {isHttpUrl(source.sourceUrl) ? (
              <a href={source.sourceUrl} rel="nofollow noreferrer" target="_blank">{source.sourceUrl}</a>
            ) : source.sourceUrl}
            {source.note && <p class="small">{source.note}</p>}
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
