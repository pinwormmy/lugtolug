---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAdminSession } from "@/lib/auth";
import { getDb, listAdminWatches } from "@/lib/db";
import { isHttpUrl } from "@/lib/watch";

const db = getDb(Astro.locals);
const session = await getAdminSession(db, Astro.request);
if (!session) {
  return Astro.redirect("/admin/login", 302);
}

const allowedStatuses = new Set(["draft", "approved", "all"]);
const requestedStatus = Astro.url.searchParams.get("status") ?? "draft";
const status = allowedStatuses.has(requestedStatus) ? requestedStatus : "draft";
const watches = await listAdminWatches(db, status as "draft" | "approved" | "all");
const approved = Astro.url.searchParams.get("approved") === "1";
const unpublished = Astro.url.searchParams.get("unpublished") === "1";
const updated = Astro.url.searchParams.get("updated") === "1";
---

<BaseLayout title="Admin watches | Lug to Lug Finder" description="Review draft and published watch records.">
  <section class="section" style="margin-top: 0;">
    <div style="display: flex; justify-content: space-between; gap: 16px; align-items: center;">
      <div>
        <h1 class="page-title" style="font-size: clamp(2.4rem, 6vw, 4rem);">Watches</h1>
        <p class="lede">Signed in as {session.user.email}</p>
        <p class="small" style="margin-top: 10px;">Draft records stay hidden from public pages until they are republished.</p>
      </div>
      <form action="/api/admin/logout" method="post">
        <button class="button secondary" type="submit">Log out</button>
      </form>
    </div>

    {(approved || unpublished || updated) && (
      <p class="notice" style="margin-top: 18px;">
        {approved && "Watch record published."}
        {unpublished && "Watch record moved to draft."}
        {updated && "Watch record updated."}
      </p>
    )}

    <nav class="admin-tabs" aria-label="Watch status">
      <a class={status === "draft" ? "active" : ""} href="/admin/watches">Draft</a>
      <a class={status === "approved" ? "active" : ""} href="/admin/watches?status=approved">Published</a>
      <a class={status === "all" ? "active" : ""} href="/admin/watches?status=all">All</a>
      <a href="/admin/submissions">Submissions</a>
    </nav>

    <div class="panel" style="margin-top: 24px; overflow-x: auto;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Status</th>
            <th>Watch</th>
            <th>Reference</th>
            <th>Source</th>
            <th>Updated</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {watches.map((watch) => (
            <tr>
              <td>{watch.status}</td>
              <td>{[watch.brand, watch.model].filter(Boolean).join(" ")}</td>
              <td>{watch.reference || "No reference"}</td>
              <td>
                {watch.sources[0]?.sourceUrl && isHttpUrl(watch.sources[0].sourceUrl) ? (
                  <a href={watch.sources[0].sourceUrl} target="_blank" rel="noreferrer">{watch.sources[0].sourceUrl}</a>
                ) : (
                  watch.sources[0]?.sourceUrl || "No source"
                )}
              </td>
              <td>{new Date(watch.updatedAt).toLocaleString("en-US")}</td>
              <td><a class="button secondary" href={`/admin/watches/${watch.id}`}>{watch.status === "approved" ? "Manage" : "Edit"}</a></td>
            </tr>
          ))}
          {watches.length === 0 && (
            <tr>
              <td colspan="6">No {status === "all" ? "" : status} watches.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
