{
  "name": "lugtolug-finder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "astro preview",
    "deploy:check": "npm run typecheck && npm test && npm run build",
    "cf:pages:create": "wrangler pages project create lugtolug --production-branch main --compatibility-date 2026-05-16",
    "cf:secret:session": "wrangler pages secret put SESSION_SECRET --project-name lugtolug",
    "cf:preview": "npm run build && wrangler pages dev dist --d1 DB=local-development-placeholder",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:create:remote": "wrangler d1 create lugtolug-finder",
    "db:migrate:remote": "wrangler d1 migrations apply lugtolug-finder --remote",
    "db:seed:local": "wrangler d1 execute DB --local --file=./data/seed.sql",
    "db:seed:remote": "wrangler d1 execute lugtolug-finder --remote --file=./data/seed.sql",
    "kv:create:session": "wrangler kv namespace create SESSION",
    "admin:sql": "node scripts/create-admin-sql.mjs",
    "data:duplicates": "node scripts/watch-duplicate-candidates.mjs",
    "smoke:workflow": "node scripts/workflow-smoke.mjs",
    "test": "vitest run",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.2",
    "@astrojs/react": "^4.3.0",
    "astro": "^5.9.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@cloudflare/workers-types": "^4.20250525.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5",
    "wrangler": "^4.18.0"
  }
}
